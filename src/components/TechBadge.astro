---
interface Props {
  name: string;
}

const { name } = Astro.props;
---

<span class="tech-badge">{name}</span>

<style>
  .tech-badge {
    display: inline-block;
    padding: 0.25rem 0.5rem;
    background: var(--border);
    border-radius: 4px;
    font-size: 0.75rem;
    color: var(--text);
  }
</style>