---
import TechBadge from './TechBadge.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  technologies: string[];
  slug: string;
  featured?: boolean;
  devPeriod?: string;
  type?: string;
}

const { title, description, image, technologies, slug, featured, devPeriod, type } = Astro.props;

// 이미지가 없거나 placeholder 면 default 이미지 사용
const defaultImage = '/images/defult.jpeg';
const hasRealImage = image && image !== '/images/placeholder.svg' && image !== defaultImage;
const displayImage = hasRealImage ? image : defaultImage;
---

<a href={`/projects/${slug}`} class="project-card" data-featured={featured} data-type={type}>
  <div class="card-image">
    <img src={displayImage} alt={title} loading="lazy" />
  </div>
  <div class="card-content">
    <h3>{title}</h3>
    <p class="description">{description}</p>
    {devPeriod && (
      <p class="dev-period">📅 {devPeriod}</p>
    )}
    <div class="tech-stack">
      {technologies.map((tech) => <TechBadge name={tech} />)}
    </div>
  </div>
</a>

<style>
  .project-card {
    display: block;
    background: linear-gradient(145deg, rgba(75, 77, 80, 0.7) 0%, rgba(60, 62, 65, 0.8) 100%);
    border: 1px solid rgba(120, 123, 126, 0.25);
    border-top: 1px solid rgba(150, 153, 156, 0.4);
    border-left: 1px solid rgba(150, 153, 156, 0.4);
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    backdrop-filter: blur(10px);
    /* 기본 상태: 약간 뜬 상태 */
    transform: translateY(-3px);
    box-shadow: 
      0 6px 24px rgba(0, 0, 0, 0.25),
      0 0 30px rgba(255, 255, 255, 0.03),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }

  .project-card:hover {
    /* 호버: 안으로 눌리는 효과 */
    transform: translateY(1px) scale(0.99);
    box-shadow: 
      0 2px 12px rgba(0, 0, 0, 0.3),
      0 0 20px rgba(255, 255, 255, 0.05),
      inset 0 2px 8px rgba(0, 0, 0, 0.2);
    border-color: rgba(170, 173, 176, 0.6);
    border-top-color: rgba(180, 183, 186, 0.7);
    border-left-color: rgba(180, 183, 186, 0.7);
    text-decoration: none;
  }

  .project-card:active {
    /* 클릭: 완전히 눌림 */
    transform: translateY(2px) scale(0.98);
    box-shadow: 
      0 1px 4px rgba(0, 0, 0, 0.4),
      inset 0 3px 12px rgba(0, 0, 0, 0.3);
    border-color: rgba(190, 193, 196, 0.8);
  }

  .project-card[data-featured="true"] {
    border-color: var(--primary);
  }

  .card-image {
    width: 100%;
    height: 200px;
    overflow: hidden;
    background: var(--border);
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-content {
    padding: 1rem;
  }

  h3 {
    color: #ffffff;
    font-size: 1.125rem;
    margin-bottom: 0.5rem;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
  }

  .description {
    color: var(--text-muted);
    font-size: 0.875rem;
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }

  .dev-period {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .tech-stack {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
</style>
