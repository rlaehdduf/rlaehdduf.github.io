---
// ProjectCard.astro - GitHub 스타일 + 절제된 Neon Purple/Cyan 포인트
// 게임 개발자 포트폴리오용

import TechBadge from './TechBadge.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  technologies: string[];
  slug: string;
  featured?: boolean;
  devPeriod?: string;
  type?: string;
}

const { title, description, image, technologies, slug, featured, devPeriod, type } = Astro.props;

const defaultImage = '/images/defult.jpeg';
const hasRealImage = image && image !== '/images/placeholder.svg' && image !== defaultImage;
const displayImage = hasRealImage ? image : defaultImage;
---

<a href={`/projects/${slug}`} class="project-card" data-featured={featured} data-type={type}>
  <div class="card-image">
    <img src={displayImage} alt={title} loading="lazy" />
    <div class="card-overlay"></div>
  </div>
  <div class="card-content">
    <h3>{title}</h3>
    <p class="description">{description}</p>
    {devPeriod && (
      <p class="dev-period">📅 {devPeriod}</p>
    )}
    <div class="tech-stack">
      {technologies.map((tech) => <TechBadge name={tech} />)}
    </div>
    <span class="view-button">View Project</span>
  </div>
</a>

<style>
  /* ===== 컬러 시스템 ===== */
  .project-card {
    --bg-primary: #0D0D0E;
    --bg-card: #111827;
    --border-color: #1F2937;
    --text-primary: #E5E7EB;
    --text-secondary: #9CA3AF;
    --purple: #9333EA;
    --cyan: #22D3EE;

    display: block;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.2s ease, border-color 0.2s ease, opacity 0.2s ease;
    text-decoration: none;
    cursor: pointer;
    position: relative;
    z-index: 1;
  }

  .project-card:hover {
    border-color: var(--cyan);
    transform: translateY(-2px);
    text-decoration: none;
  }

  /* ===== 이미지 + 오버레이 ===== */
  .card-image {
    position: relative;
    width: 100%;
    height: 160px;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
    transition: background 0.2s ease;
  }

  .project-card:hover .card-overlay {
    background: rgba(0, 0, 0, 0);
  }

  /* ===== 카드 내용 ===== */
  .card-content {
    padding: 1rem;
  }

  h3 {
    color: var(--text-primary);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .description {
    color: var(--text-secondary);
    font-size: 0.85rem;
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }

  .dev-period {
    font-size: 0.75rem;
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
  }

  .tech-stack {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  /* ===== 버튼 스타일 ===== */
  .view-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 0.625rem 1rem;
    background: var(--cyan);
    color: var(--bg-primary);
    font-weight: 600;
    font-size: 0.875rem;
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .project-card:hover .view-button {
    box-shadow: 0 0 12px rgba(34, 211, 238, 0.25);
  }

  /* ===== Featured 카드 ===== */
  .project-card[data-featured="true"] {
    border-color: rgba(147, 51, 234, 0.3);
  }

  .project-card[data-featured="true"]:hover {
    border-color: var(--purple);
  }
</style>