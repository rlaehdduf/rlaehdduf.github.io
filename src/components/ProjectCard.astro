---
import TechBadge from './TechBadge.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  technologies: string[];
  slug: string;
  featured?: boolean;
  devPeriod?: string;
  type?: string;
}

const { title, description, image, technologies, slug, featured, devPeriod, type } = Astro.props;

// 이미지가 없거나 placeholder 면 default 이미지 사용
const defaultImage = '/images/defult.jpeg';
const hasRealImage = image && image !== '/images/placeholder.svg' && image !== defaultImage;
const displayImage = hasRealImage ? image : defaultImage;
---

<a href={`/projects/${slug}`} class="project-card" data-featured={featured} data-type={type}>
  <div class="card-image">
    <img src={displayImage} alt={title} loading="lazy" />
  </div>
  <div class="card-content">
    <h3>{title}</h3>
    <p class="description">{description}</p>
    {devPeriod && (
      <p class="dev-period">📅 {devPeriod}</p>
    )}
    <div class="tech-stack">
      {technologies.map((tech) => <TechBadge name={tech} />)}
    </div>
  </div>
</a>

<style>
  .project-card {
    display: block;
    background: linear-gradient(145deg, rgba(80, 82, 85, 0.8) 0%, rgba(55, 57, 60, 0.9) 100%);
    border: 1px solid rgba(90, 93, 96, 0.4);
    border-top: 1px solid rgba(110, 113, 116, 0.5);
    border-left: 1px solid rgba(110, 113, 116, 0.5);
    border-radius: 12px;
    overflow: hidden;
    transition: box-shadow 0.3s, border-color 0.3s, transform 0.2s ease-out;
    backdrop-filter: blur(10px);
    box-shadow: 
      12px 12px 24px rgba(0, 0, 0, 0.5),
      8px 8px 40px rgba(0, 0, 0, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  .project-card:hover {
    transform: translateY(-8px) scale(1.02);
    box-shadow: 
      20px 20px 40px rgba(0, 0, 0, 0.6),
      12px 12px 50px rgba(0, 0, 0, 0.5),
      inset 0 2px 10px rgba(0, 0, 0, 0.3);
    border-color: rgba(100, 103, 106, 0.6);
    border-top-color: rgba(120, 123, 126, 0.7);
    border-left-color: rgba(120, 123, 126, 0.7);
    text-decoration: none;
  }

  .project-card:active {
    transform: translateY(2px) scale(0.98);
    box-shadow: 
      4px 4px 12px rgba(0, 0, 0, 0.7),
      inset 0 4px 16px rgba(0, 0, 0, 0.4);
    border-color: rgba(110, 113, 116, 0.8);
    border-top-color: rgba(130, 133, 136, 0.9);
    border-left-color: rgba(130, 133, 136, 0.9);
    transition: transform 0.05s ease-out, box-shadow 0.05s;
  }

  .project-card[data-featured="true"] {
    border-color: rgba(120, 123, 126, 0.6);
    border-top-color: rgba(140, 143, 146, 0.7);
    border-left-color: rgba(140, 143, 146, 0.7);
    background: linear-gradient(145deg, rgba(85, 87, 90, 0.85) 0%, rgba(60, 62, 65, 0.95) 100%);
  }

  .card-image {
    width: 100%;
    height: 200px;
    overflow: hidden;
    background: var(--border);
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-content {
    padding: 1rem;
  }

  h3 {
    color: #ffffff;
    font-size: 1.125rem;
    margin-bottom: 0.5rem;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
  }

  .description {
    color: var(--text-muted);
    font-size: 0.875rem;
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }

  .dev-period {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .tech-stack {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
</style>
