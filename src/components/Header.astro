---
const pathname = Astro.url.pathname;
---

<header>
  <nav>
    <a href="/" class="nav-link">
      Portfolio
    </a>
    <button class="menu-toggle" id="menuToggle" aria-label="Toggle menu" type="button">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>
  
  <div class="filter-menu" id="filterMenu">
    <div class="filter-header">
      <h3>🔍 필터</h3>
      <button class="close-btn" id="closeBtn" aria-label="Close menu">&times;</button>
    </div>
    <div class="filter-options">
      <label class="filter-option">
        <input type="checkbox" value="all" checked>
        <span>All</span>
      </label>
      <label class="filter-option">
        <input type="checkbox" value="unity">
        <span>Unity</span>
      </label>
      <label class="filter-option">
        <input type="checkbox" value="web">
        <span>Web</span>
      </label>
      <label class="filter-option">
        <input type="checkbox" value="package">
        <span>Package</span>
      </label>
      <label class="filter-option">
        <input type="checkbox" value="server">
        <span>Server</span>
      </label>
      <label class="filter-option">
        <input type="checkbox" value="docs">
        <span>Docs</span>
      </label>
    </div>
  </div>
</header>

<style>
  header {
    padding: 1rem 2rem;
    background: rgba(30, 41, 59, 0.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
  }

  .nav-link {
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--text);
    text-decoration: none;
  }

  .nav-link:hover {
    color: var(--primary);
  }

  .menu-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: transparent;
    border: 2px solid transparent;
    cursor: pointer;
    padding: 10px;
    z-index: 102;
    position: relative;
    border-radius: 8px;
    transition: background 0.2s, border-color 0.2s;
  }

  .menu-toggle:hover {
    background: var(--border);
    border-color: var(--primary);
  }

  .menu-toggle:hover span {
    background: var(--primary);
  }

  .menu-toggle:active {
    transform: scale(0.95);
  }

  .menu-toggle.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .menu-toggle.active span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle.active span:nth-child(3) {
    transform: rotate(-45deg) translate(7px, -6px);
  }

  .menu-toggle span {
    width: 25px;
    height: 3px;
    background: var(--text);
    border-radius: 2px;
    transition: all 0.3s ease;
    display: block;
  }

  .filter-menu {
    position: fixed;
    top: 80px;
    right: -350px;
    width: 300px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.4);
    transition: right 0.3s ease;
    z-index: 99;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
  }

  .filter-menu.open {
    right: 20px;
  }

  .filter-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  .filter-header h3 {
    color: var(--text);
    font-size: 1.125rem;
    margin: 0;
  }

  .close-btn {
    background: none;
    border: none;
    color: var(--text-muted);
    font-size: 1.5rem;
    cursor: pointer;
    padding: 0;
    line-height: 1;
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    transition: background 0.2s;
  }

  .close-btn:hover {
    color: var(--text);
    background: var(--border);
  }

  .filter-options {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .filter-option {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    cursor: pointer;
    padding: 0.75rem;
    border-radius: 6px;
    transition: background 0.2s;
    user-select: none;
  }

  .filter-option:hover {
    background: var(--border);
  }

  .filter-option input[type="checkbox"] {
    width: 18px;
    height: 18px;
    accent-color: var(--primary);
    cursor: pointer;
    flex-shrink: 0;
  }

  .filter-option span {
    color: var(--text);
    font-size: 0.95rem;
    flex: 1;
  }
</style>

<script>
  const menuToggle = document.getElementById('menuToggle');
  const filterMenu = document.getElementById('filterMenu');
  const closeBtn = document.getElementById('closeBtn');
  
  console.log('Header script loaded');
  console.log('menuToggle:', menuToggle);
  console.log('filterMenu:', filterMenu);
  console.log('closeBtn:', closeBtn);

  function toggleMenu() {
    console.log('toggleMenu called');
    console.log('menuToggle classes before:', menuToggle?.className);
    console.log('filterMenu classes before:', filterMenu?.className);
    
    menuToggle.classList.toggle('active');
    filterMenu.classList.toggle('open');
    
    console.log('menuToggle classes after:', menuToggle?.className);
    console.log('filterMenu classes after:', filterMenu?.className);
  }

  if (menuToggle) {
    menuToggle.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      console.log('menuToggle clicked');
      toggleMenu();
    });
  }

  if (closeBtn) {
    closeBtn.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      console.log('closeBtn clicked');
      toggleMenu();
    });
  }

  document.addEventListener('click', function(e) {
    if (filterMenu && !filterMenu.contains(e.target) && menuToggle && !menuToggle.contains(e.target)) {
      console.log('click outside, closing menu');
      filterMenu.classList.remove('open');
      menuToggle.classList.remove('active');
    }
  });

  if (filterMenu) {
    filterMenu.addEventListener('click', function(e) {
      e.stopPropagation();
    });
  }

  const checkboxes = filterMenu ? filterMenu.querySelectorAll('input[type="checkbox"]') : [];
  const allCheckbox = checkboxes[0];
  const typeCheckboxes = Array.from(checkboxes).slice(1);

  if (allCheckbox) {
    allCheckbox.addEventListener('change', function() {
      if (this.checked) {
        typeCheckboxes.forEach(cb => cb.checked = false);
        updateFilters(['all']);
      } else {
        this.checked = true;
      }
    });
  }

  typeCheckboxes.forEach(checkbox => {
    checkbox.addEventListener('change', function() {
      if (this.checked) {
        allCheckbox.checked = false;
      }
      
      const selectedTypes = typeCheckboxes
        .filter(cb => cb.checked)
        .map(cb => cb.value);
      
      if (selectedTypes.length === 0) {
        allCheckbox.checked = true;
        updateFilters(['all']);
      } else {
        updateFilters(selectedTypes);
      }
    });
  });

  function updateFilters(types) {
    const cards = document.querySelectorAll('.project-card');
    console.log('updateFilters called with:', types);
    console.log('cards found:', cards.length);
    
    cards.forEach(card => {
      const projectType = card.getAttribute('data-type');
      if (types.includes('all') || types.includes(projectType)) {
        card.style.display = 'block';
      } else {
        card.style.display = 'none';
      }
    });
  }
</script>
