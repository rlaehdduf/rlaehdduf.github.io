---
const pathname = Astro.url.pathname;
---

<header>
  <nav>
    <a href="/" class="nav-link">
      Portfolio
    </a>
    <button class="menu-toggle" id="menuToggle" aria-label="Toggle menu" type="button">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>
  
  <div class="filter-menu" id="filterMenu">
    <div class="filter-header">
      <h3>📂 Projects</h3>
      <button class="close-btn" id="closeBtn" aria-label="Close menu">&times;</button>
    </div>
    
    <div class="filter-content">
      <p class="menu-hint">폴더 클릭: 확장/접기<br>프로젝트 클릭: 이동</p>
      <div class="project-tree" id="projectTree"></div>
    </div>
  </div>
</header>

<style is:global>
  /* ===== 컬러 시스템 ===== */
  header {
    --bg-primary: #0D0D0E;
    --bg-card: #111827;
    --border-color: #1F2937;
    --text-primary: #E5E7EB;
    --text-secondary: #9CA3AF;
    --purple: #9333EA;
    --cyan: #22D3EE;

    padding: 1rem 2rem;
    background: var(--bg-card);
    border-bottom: 1px solid var(--border-color);
    position: relative;
    z-index: 1000;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
  }

  .nav-link {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .nav-link:hover {
    color: var(--cyan);
    text-decoration: none;
  }

  .menu-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: transparent;
    border: 1px solid var(--border-color);
    cursor: pointer;
    padding: 10px;
    z-index: 10001;
    position: relative;
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .menu-toggle:hover {
    background: rgba(147, 51, 234, 0.1);
    border-color: var(--purple);
  }

  .menu-toggle:hover span {
    background: var(--cyan);
  }

  .menu-toggle:active {
    transform: scale(0.95);
  }

  .menu-toggle.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .menu-toggle.active span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle.active span:nth-child(3) {
    transform: rotate(-45deg) translate(7px, -6px);
  }

  .menu-toggle span {
    width: 22px;
    height: 2px;
    background: var(--text-secondary);
    border-radius: 2px;
    transition: all 0.3s ease;
    display: block;
  }

  /* ===== Filter Menu ===== */
  .filter-menu {
    position: fixed;
    top: 70px;
    right: 20px;
    width: 320px;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 0;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
    transition: opacity 0.2s ease, transform 0.2s ease;
    z-index: 10000;
    max-height: calc(100vh - 100px);
    overflow-y: auto;
    opacity: 0;
    transform: translateX(20px);
    pointer-events: none;
  }

  .filter-menu.open {
    opacity: 1;
    transform: translateX(0);
    pointer-events: auto;
  }

  .filter-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem;
    border-bottom: 1px solid var(--border-color);
    background: var(--bg-primary);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .filter-header h3 {
    color: var(--text-primary);
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
  }

  .close-btn {
    background: transparent;
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    font-size: 1.25rem;
    cursor: pointer;
    padding: 0;
    line-height: 1;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    transition: all 0.2s ease;
  }

  .close-btn:hover {
    color: var(--cyan);
    border-color: var(--cyan);
  }

  .filter-content {
    padding: 1rem;
  }

  .menu-hint {
    color: var(--text-secondary);
    font-size: 0.75rem;
    margin-bottom: 1rem;
    padding: 0.5rem;
    background: var(--bg-primary);
    border-radius: 6px;
    text-align: center;
    line-height: 1.6;
  }

  .project-tree {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .tree-folder {
    border-radius: 8px;
    overflow: hidden;
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
  }

  .tree-folder-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    cursor: pointer;
    transition: background 0.2s ease;
    user-select: none;
  }

  .tree-folder-header:hover {
    background: rgba(147, 51, 234, 0.1);
  }

  .tree-folder-arrow {
    font-size: 0.625rem;
    color: var(--text-secondary);
    transition: transform 0.2s ease;
    width: 16px;
    text-align: center;
    display: inline-block;
  }

  .tree-folder-arrow.expanded {
    transform: rotate(90deg);
  }

  .tree-folder-icon {
    font-size: 1rem;
    display: inline-block;
    width: 20px;
    text-align: center;
  }

  .tree-folder-label {
    color: var(--text-primary);
    font-size: 0.85rem;
    font-weight: 600;
    flex: 1;
  }

  .tree-folder-count {
    color: var(--text-secondary);
    font-size: 0.7rem;
    background: var(--bg-card);
    padding: 0.125rem 0.5rem;
    border-radius: 10px;
    border: 1px solid var(--border-color);
    font-family: 'JetBrains Mono', monospace;
  }

  .tree-children {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.2s ease;
    display: flex;
    flex-direction: column;
    padding: 0;
    margin: 0;
  }

  .tree-children.expanded {
    max-height: 800px;
    border-top: 1px solid var(--border-color);
    padding: 0.5rem 0;
  }

  .tree-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 1rem 0.5rem 2.25rem;
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
    width: 100%;
    box-sizing: border-box;
  }

  .tree-item:hover {
    background: rgba(34, 211, 238, 0.1);
  }

  .tree-item-icon {
    font-size: 0.8rem;
    display: inline-block;
    width: 20px;
    text-align: center;
    flex-shrink: 0;
  }

  .tree-item-label {
    color: var(--text-primary);
    font-size: 0.8rem;
    flex: 1;
    text-align: left;
  }
</style>

<script>
  const projects = [
    { slug: 'defencegame', title: 'DefenceGame', type: 'unity', icon: '🎯' },
    { slug: 'greeddungeon', title: 'GreedDungeon', type: 'unity', icon: '⚔️' },
    { slug: 'pathfinder', title: 'Pathfinder', type: 'unity', icon: '🗺️' },
    { slug: 'shotup', title: 'ShotUp', type: 'unity', icon: '🎯' },
    { slug: 'community-board', title: 'CommunityBoard', type: 'web', icon: '💬' },
    { slug: 'cookie-clicker', title: 'Cookie Clicker', type: 'server', icon: '🍪' },
    { slug: 'kirdia-simulator', title: 'Kirdia Simulator', type: 'docs', icon: '📖' },
    { slug: 'gamedevtoolkit', title: 'GameDevToolkit', type: 'package', icon: '🧰' },
  ];

  const projectTypes = [
    { value: 'unity', label: 'Unity', icon: '🎮' },
    { value: 'web', label: 'Web', icon: '🌐' },
    { value: 'package', label: 'Package', icon: '📦' },
    { value: 'server', label: 'Server', icon: '🖥️' },
    { value: 'docs', label: 'Docs', icon: '📄' },
  ];

  function initMenu() {
    const menuToggle = document.getElementById('menuToggle');
    const filterMenu = document.getElementById('filterMenu');
    const closeBtn = document.getElementById('closeBtn');
    const projectTree = document.getElementById('projectTree');

    if (!menuToggle || !filterMenu || !projectTree) {
      console.error('Menu elements not found');
      return;
    }

    console.log('✅ Menu elements found');

    function toggleMenu() {
      menuToggle.classList.toggle('active');
      filterMenu.classList.toggle('open');
      console.log('Menu toggled:', filterMenu.classList.contains('open') ? 'OPEN' : 'CLOSED');
    }

    menuToggle.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      toggleMenu();
    });

    if (closeBtn) {
      closeBtn.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        toggleMenu();
      });
    }

    document.addEventListener('click', function(e) {
      if (!filterMenu.contains(e.target) && !menuToggle.contains(e.target)) {
        filterMenu.classList.remove('open');
        menuToggle.classList.remove('active');
      }
    });

    // 스크롤 시 메뉴 닫기
    let scrollTimeout;
    window.addEventListener('scroll', function() {
      if (filterMenu.classList.contains('open')) {
        clearTimeout(scrollTimeout);
        scrollTimeout = setTimeout(function() {
          filterMenu.classList.remove('open');
          menuToggle.classList.remove('active');
        }, 100);
      }
    }, { passive: true });

    filterMenu.addEventListener('click', function(e) {
      e.stopPropagation();
    });

    function renderTree() {
      console.log('🌲 Rendering tree...');
      projectTree.innerHTML = '';

      projectTypes.forEach(type => {
        const typeProjects = projects.filter(p => p.type === type.value);
        if (typeProjects.length === 0) return;

        console.log(`  📁 ${type.label}: ${typeProjects.length} projects`);

        const folder = document.createElement('div');
        folder.className = 'tree-folder';

        const header = document.createElement('div');
        header.className = 'tree-folder-header';
        header.innerHTML = `
          <span class="tree-folder-arrow">▶</span>
          <span class="tree-folder-icon">${type.icon}</span>
          <span class="tree-folder-label">${type.label}</span>
          <span class="tree-folder-count">${typeProjects.length}</span>
        `;

        const children = document.createElement('div');
        children.className = 'tree-children';

        typeProjects.forEach(project => {
          const item = document.createElement('a');
          item.className = 'tree-item';
          item.href = `/projects/${project.slug}`;
          item.innerHTML = `
            <span class="tree-item-icon">${project.icon}</span>
            <span class="tree-item-label">${project.title}</span>
          `;
          children.appendChild(item);
        });

        folder.appendChild(header);
        folder.appendChild(children);
        projectTree.appendChild(folder);

        header.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();
          
          const isExpanded = children.classList.contains('expanded');
          console.log(`  📂 ${type.label} clicked - ${isExpanded ? 'COLLAPSE' : 'EXPAND'}`);
          
          // Close all folders
          document.querySelectorAll('.tree-children.expanded').forEach(el => {
            el.classList.remove('expanded');
            const arrow = el.previousElementSibling?.querySelector('.tree-folder-arrow');
            if (arrow) arrow.classList.remove('expanded');
          });

          // Toggle current folder
          if (!isExpanded) {
            children.classList.add('expanded');
            const arrow = header.querySelector('.tree-folder-arrow');
            if (arrow) arrow.classList.add('expanded');
          }
        });
      });

      console.log('✅ Tree rendered');
    }

    renderTree();
  }

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMenu);
  } else {
    initMenu();
  }

  console.log('🚀 Menu initialized');
</script>
