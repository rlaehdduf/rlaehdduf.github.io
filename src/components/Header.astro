---
const pathname = Astro.url.pathname;
---

<header>
  <nav>
    <a href="/" class:list={['nav-link', { active: pathname === '/' }]}>
      Portfolio
    </a>
  </nav>
</header>

<style>
  header {
    padding: 1rem 2rem;
    background: var(--card-bg);
    border-bottom: 1px solid var(--border);
  }

  nav {
    display: flex;
    align-items: center;
  }

  .nav-link {
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--text);
  }

  .nav-link:hover {
    color: var(--primary);
    text-decoration: none;
  }
</style>