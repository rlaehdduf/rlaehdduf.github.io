---
const pathname = Astro.url.pathname;
---

<header>
  <nav>
    <a href="/" class="nav-link">
      Portfolio
    </a>
    <button class="menu-toggle" id="menuToggle" aria-label="Toggle menu" type="button">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>
  
  <div class="filter-menu" id="filterMenu">
    <div class="filter-header">
      <h3>📂 Projects</h3>
      <button class="close-btn" id="closeBtn" aria-label="Close menu">&times;</button>
    </div>
    
    <div class="filter-content">
      <p class="menu-hint">폴더 클릭: 확장/접기<br>프로젝트 클릭: 이동</p>
      <div class="project-tree" id="projectTree"></div>
    </div>
  </div>
</header>

<style>
  header {
    padding: 1rem 2rem;
    background: linear-gradient(180deg, rgba(45, 47, 50, 0.98) 0%, rgba(35, 37, 39, 0.95) 100%);
    backdrop-filter: blur(15px);
    border-bottom: 1px solid rgba(120, 123, 126, 0.3);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
  }

  .nav-link {
    font-size: 1.5rem;
    font-weight: bold;
    color: #e5e7eb;
    text-decoration: none;
  }

  .nav-link:hover {
    color: #ffffff;
  }

  .menu-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: transparent;
    border: 2px solid transparent;
    cursor: pointer;
    padding: 10px;
    z-index: 102;
    position: relative;
    border-radius: 8px;
    transition: all 0.2s;
  }

  .menu-toggle:hover {
    background: rgba(100, 103, 106, 0.3);
    border-color: rgba(120, 123, 126, 0.5);
  }

  .menu-toggle:hover span {
    background: #e5e7eb;
  }

  .menu-toggle:active {
    transform: scale(0.95);
    background: rgba(100, 103, 106, 0.4);
  }

  .menu-toggle.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .menu-toggle.active span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle.active span:nth-child(3) {
    transform: rotate(-45deg) translate(7px, -6px);
  }

  .menu-toggle span {
    width: 25px;
    height: 3px;
    background: #d1d5db;
    border-radius: 2px;
    transition: all 0.3s ease;
    display: block;
  }

  .filter-menu {
    position: fixed;
    top: 80px;
    right: -350px;
    width: 340px;
    background: linear-gradient(180deg, rgba(50, 52, 55, 0.98) 0%, rgba(40, 42, 45, 0.95) 100%);
    border: 1px solid rgba(90, 93, 96, 0.5);
    border-radius: 12px;
    padding: 0;
    box-shadow: 
      0 10px 40px rgba(0, 0, 0, 0.5),
      0 0 60px rgba(0, 0, 0, 0.3);
    transition: right 0.3s ease;
    z-index: 99;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
    backdrop-filter: blur(15px);
  }

  .filter-menu.open {
    right: 20px;
  }

  .filter-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem;
    border-bottom: 1px solid rgba(90, 93, 96, 0.5);
    background: linear-gradient(180deg, rgba(60, 62, 65, 0.9) 0%, rgba(50, 52, 55, 0.8) 100%);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .filter-header h3 {
    color: #e5e7eb;
    font-size: 1.125rem;
    margin: 0;
  }

  .close-btn {
    background: rgba(90, 93, 96, 0.3);
    border: 1px solid rgba(110, 113, 116, 0.4);
    color: #d1d5db;
    font-size: 1.5rem;
    cursor: pointer;
    padding: 0;
    line-height: 1;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    transition: all 0.2s;
  }

  .close-btn:hover {
    color: #ffffff;
    background: rgba(100, 103, 106, 0.5);
    border-color: rgba(120, 123, 126, 0.6);
  }

  .filter-content {
    padding: 1rem;
  }

  .menu-hint {
    color: #9ca3af;
    font-size: 0.75rem;
    margin-bottom: 1rem;
    padding: 0.5rem;
    background: rgba(70, 72, 75, 0.3);
    border-radius: 6px;
    text-align: center;
    line-height: 1.6;
  }

  .project-tree {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .tree-folder {
    border-radius: 8px;
    overflow: hidden;
    background: rgba(60, 62, 65, 0.4);
    border: 1px solid rgba(90, 93, 96, 0.3);
  }

  .tree-folder-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    cursor: pointer;
    transition: background 0.2s;
    user-select: none;
  }

  .tree-folder-header:hover {
    background: rgba(80, 82, 85, 0.5);
  }

  .tree-folder-arrow {
    font-size: 0.75rem;
    color: #9ca3af;
    transition: transform 0.3s ease;
    width: 16px;
    text-align: center;
    display: inline-block;
  }

  .tree-folder-arrow.expanded {
    transform: rotate(90deg);
  }

  .tree-folder-icon {
    font-size: 1.125rem;
    display: inline-block;
    width: 24px;
    text-align: center;
  }

  .tree-folder-label {
    color: #e5e7eb;
    font-size: 0.9rem;
    font-weight: 600;
    flex: 1;
  }

  .tree-folder-count {
    color: #9ca3af;
    font-size: 0.75rem;
    background: rgba(80, 82, 85, 0.5);
    padding: 0.125rem 0.5rem;
    border-radius: 10px;
    border: 1px solid rgba(100, 103, 106, 0.3);
  }

  .tree-children {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
    background: rgba(45, 47, 50, 0.5);
    display: flex;
    flex-direction: column;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .tree-children.expanded {
    max-height: 800px;
    border-top: 1px solid rgba(90, 93, 96, 0.3);
    padding: 0.5rem 0;
  }

  .tree-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 1rem 0.625rem 2.5rem;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
    width: 100%;
    box-sizing: border-box;
  }

  .tree-item:hover {
    background: rgba(90, 93, 96, 0.4);
  }

  .tree-item-icon {
    font-size: 0.875rem;
    display: inline-block;
    width: 20px;
    text-align: center;
    flex-shrink: 0;
  }

  .tree-item-label {
    color: #e5e7eb;
    font-size: 0.85rem;
    flex: 1;
    text-align: left;
    white-space: normal;
    word-break: break-word;
  }
</style>

<script>
  if (typeof window !== 'undefined') {
    window.initProjectMenu = function() {
      const projects = [
        { slug: 'defencegame', title: 'DefenceGame', type: 'unity', icon: '🎯' },
        { slug: 'greeddungeon', title: 'GreedDungeon', type: 'unity', icon: '⚔️' },
        { slug: 'pathfinder', title: 'Pathfinder', type: 'unity', icon: '🗺️' },
        { slug: 'shotup', title: 'ShotUp', type: 'unity', icon: '🎯' },
        { slug: 'community-board', title: 'CommunityBoard', type: 'web', icon: '💬' },
        { slug: 'cookie-clicker', title: 'Cookie Clicker', type: 'server', icon: '🍪' },
        { slug: 'kirdia-simulator', title: 'Kirdia Simulator', type: 'docs', icon: '📖' },
        { slug: 'gamedevtoolkit', title: 'GameDevToolkit', type: 'package', icon: '🧰' },
      ];

      const projectTypes = [
        { value: 'unity', label: 'Unity', icon: '🎮' },
        { value: 'web', label: 'Web', icon: '🌐' },
        { value: 'package', label: 'Package', icon: '📦' },
        { value: 'server', label: 'Server', icon: '🖥️' },
        { value: 'docs', label: 'Docs', icon: '📄' },
      ];

      const menuToggle = document.getElementById('menuToggle');
      const filterMenu = document.getElementById('filterMenu');
      const closeBtn = document.getElementById('closeBtn');
      const projectTree = document.getElementById('projectTree');

      if (!menuToggle || !filterMenu || !projectTree) {
        console.error('Menu elements not found');
        return;
      }

      function toggleMenu() {
        menuToggle.classList.toggle('active');
        filterMenu.classList.toggle('open');
      }

      menuToggle.addEventListener('click', toggleMenu);
      if (closeBtn) closeBtn.addEventListener('click', toggleMenu);

      document.addEventListener('click', (e) => {
        if (!filterMenu.contains(e.target) && !menuToggle.contains(e.target)) {
          filterMenu.classList.remove('open');
          menuToggle.classList.remove('active');
        }
      });

      filterMenu.addEventListener('click', (e) => e.stopPropagation());

      function renderTree() {
        projectTree.innerHTML = '';

        projectTypes.forEach(type => {
          const typeProjects = projects.filter(p => p.type === type.value);
          if (typeProjects.length === 0) return;

          const folder = document.createElement('div');
          folder.className = 'tree-folder';

          const header = document.createElement('div');
          header.className = 'tree-folder-header';
          header.innerHTML = `
            <span class="tree-folder-arrow">▶</span>
            <span class="tree-folder-icon">${type.icon}</span>
            <span class="tree-folder-label">${type.label}</span>
            <span class="tree-folder-count">${typeProjects.length}</span>
          `;

          const children = document.createElement('div');
          children.className = 'tree-children';

          typeProjects.forEach(project => {
            const item = document.createElement('a');
            item.className = 'tree-item';
            item.href = `/projects/${project.slug}`;
            item.innerHTML = `
              <span class="tree-item-icon">${project.icon}</span>
              <span class="tree-item-label">${project.title}</span>
            `;
            children.appendChild(item);
          });

          folder.appendChild(header);
          folder.appendChild(children);
          projectTree.appendChild(folder);

          header.addEventListener('click', () => {
            const isExpanded = children.classList.contains('expanded');
            
            // Close all
            document.querySelectorAll('.tree-children.expanded').forEach(el => {
              el.classList.remove('expanded');
              const arr = el.previousElementSibling?.querySelector('.tree-folder-arrow');
              if (arr) arr.classList.remove('expanded');
            });

            // Open current
            if (!isExpanded) {
              children.classList.add('expanded');
              const arrow = header.querySelector('.tree-folder-arrow');
              if (arrow) arrow.classList.add('expanded');
            }
          });
        });
      }

      renderTree();
    };

    // Run on load
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', window.initProjectMenu);
    } else {
      window.initProjectMenu();
    }
  }
</script>
