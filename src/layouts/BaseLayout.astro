---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    
    <!-- Open Graph / SNS Preview -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="Game Developer Portfolio - Unity Games, Web Applications, and Tools" />
    <meta property="og:image" content="/images/portfolio-og.png" />
    <meta property="og:url" content={Astro.url.href} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content="Game Developer Portfolio - Unity Games, Web Applications, and Tools" />
    <meta name="twitter:image" content="/images/portfolio-og.png" />
    
    <style is:global>
      /* ===== 컬러 시스템 ===== */
      :root {
        --bg-primary: #0D0D0E;
        --bg-card: #111827;
        --border-color: #1F2937;
        --text-primary: #E5E7EB;
        --text-secondary: #9CA3AF;
        --purple: #9333EA;
        --cyan: #22D3EE;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
        background: var(--bg-primary);
        color: var(--text-primary);
        line-height: 1.6;
        min-height: 100vh;
      }

      a {
        color: var(--cyan);
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      main {
        min-height: calc(100vh - 120px);
      }

      /* ===== 코드/태그용 Mono 폰트 ===== */
      code, .mono {
        font-family: 'JetBrains Mono', monospace;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>