---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TechBadge from '../../components/TechBadge.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const defaultImage = '/images/defult.jpeg';
const hasRealImage = project.data.image && project.data.image !== '/images/placeholder.svg' && project.data.image !== defaultImage;
const displayImage = hasRealImage ? project.data.image : defaultImage;
---

<BaseLayout title={project.data.title}>
  <article class="project-detail">
    <a href="/" class="back-link">← Back to Projects</a>

    <header>
      <h1>{project.data.title}</h1>
      <p class="description">{project.data.description}</p>
      {project.data.devPeriod && (
        <p class="dev-period">📅 {project.data.devPeriod}</p>
      )}
      <div class="tech-stack">
        {project.data.technologies.map((tech) => <TechBadge name={tech} />)}
      </div>
    </header>

    <div class="project-image">
      <img src={displayImage} alt={project.data.title} />
      <div class="image-overlay"></div>
    </div>

    <section class="content">
      <Content />
    </section>

    <section class="links">
      {project.data.github && (
        <a href={project.data.github} class="link-button github" target="_blank" rel="noopener">
          GitHub Repository
        </a>
      )}
      {project.data.demo && (
        <a href={project.data.demo} class="link-button demo" target="_blank" rel="noopener">
          Live Demo
        </a>
      )}
    </section>

    {project.data.type === 'web' && project.data.demo && (
      <section class="demo-frame">
        <h2>Live Preview</h2>
        <iframe src={project.data.demo} title={project.data.title} loading="lazy"></iframe>
      </section>
    )}
  </article>
</BaseLayout>

<style>
  /* ===== 컬러 시스템 ===== */
  .project-detail {
    --bg-primary: #0D0D0E;
    --bg-card: #111827;
    --border-color: #1F2937;
    --text-primary: #E5E7EB;
    --text-secondary: #9CA3AF;
    --purple: #9333EA;
    --cyan: #22D3EE;

    padding: 2rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: var(--text-secondary);
    font-size: 0.85rem;
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--cyan);
    text-decoration: none;
  }

  /* ===== Header ===== */
  header {
    margin-bottom: 2rem;
    padding: 2rem;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    position: relative;
    z-index: 1;
  }

  h1 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--text-primary);
  }

  .description {
    color: var(--text-secondary);
    font-size: 1rem;
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .dev-period {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin-bottom: 1rem;
  }

  .tech-stack {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  /* ===== Image ===== */
  .project-image {
    position: relative;
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 2rem;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    box-shadow: 
      0 4px 20px rgba(0, 0, 0, 0.4),
      0 0 30px rgba(147, 51, 234, 0.1);
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .project-image:hover {
    transform: translateY(-2px) scale(1.01);
    box-shadow: 
      0 8px 30px rgba(0, 0, 0, 0.5),
      0 0 40px rgba(34, 211, 238, 0.25);
    border-color: rgba(34, 211, 238, 0.3);
  }

  .project-image img {
    width: 100%;
    height: auto;
    display: block;
    transition: filter 0.3s ease, transform 0.3s ease;
  }

  .project-image .image-overlay {
    position: absolute;
    inset: 0;
    background: rgba(13, 13, 14, 0.65);
    transition: all 0.3s ease;
    pointer-events: none;
    z-index: 1;
  }

  .project-image:hover .image-overlay {
    background: rgba(13, 13, 14, 0.1);
  }

  .project-image:hover img {
    filter: brightness(1.1);
  }

  /* ===== Content ===== */
  .content {
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }

  .content :global(h2) {
    color: var(--text-primary);
    font-size: 1.25rem;
    margin-bottom: 1rem;
  }

  .content :global(h3) {
    color: var(--text-primary);
    font-size: 1rem;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .content :global(p) {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .content :global(ul),
  .content :global(ol) {
    color: var(--text-secondary);
    font-size: 0.9rem;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .content :global(li) {
    margin-bottom: 0.5rem;
  }

  .content :global(code) {
    background: rgba(147, 51, 234, 0.1);
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
    font-size: 0.85em;
  }

  /* ===== Buttons ===== */
  .links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .link-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    font-weight: 600;
    font-size: 0.875rem;
    border-radius: 8px;
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .link-button.github {
    background: var(--purple);
    color: var(--text-primary);
    border: 1px solid transparent;
  }

  .link-button.github:hover {
    background: rgba(147, 51, 234, 0.9);
    border-color: rgba(147, 51, 234, 0.6);
    box-shadow: 0 0 12px rgba(147, 51, 234, 0.25);
    text-decoration: none;
  }

  .link-button.demo {
    background: var(--cyan);
    color: var(--bg-primary);
    border: 1px solid transparent;
  }

  .link-button.demo:hover {
    background: rgba(34, 211, 238, 0.9);
    box-shadow: 0 0 12px rgba(34, 211, 238, 0.25);
    text-decoration: none;
  }

  /* ===== Demo Frame ===== */
  .demo-frame {
    margin-bottom: 2rem;
  }

  .demo-frame h2 {
    margin-bottom: 1rem;
    color: var(--text-primary);
    font-size: 1.125rem;
  }

  .demo-frame iframe {
    width: 100%;
    height: 500px;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--bg-card);
  }

  /* ===== Responsive ===== */
  @media (max-width: 640px) {
    .project-detail {
      padding: 1rem;
    }

    header {
      padding: 1.5rem;
    }

    h1 {
      font-size: 1.5rem;
    }

    .links {
      flex-direction: column;
    }

    .link-button {
      width: 100%;
    }
  }
</style>