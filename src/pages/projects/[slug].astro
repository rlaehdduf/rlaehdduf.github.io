---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TechBadge from '../../components/TechBadge.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

// placeholder 이미지는 259 bytes, 실제 이미지는 더 큼
const hasRealImage = project.data.image && project.data.image !== '/images/placeholder.svg';
---

<BaseLayout title={project.data.title}>
  <article class="project-detail">
    <a href="/" class="back-link">← Back to Projects</a>

    <header>
      <h1>{project.data.title}</h1>
      <p class="description">{project.data.description}</p>
      <div class="tech-stack">
        {project.data.technologies.map((tech) => <TechBadge name={tech} />)}
      </div>
    </header>

    {hasRealImage ? (
      <div class="project-image">
        <img src={project.data.image} alt={project.data.title} onerror="this.parentElement.style.display='none'" />
      </div>
    ) : (
      <div class="project-image project-image-placeholder">
        <svg class="placeholder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437" />
        </svg>
        <span class="placeholder-text">No Preview Available</span>
      </div>
    )}

    <section class="content">
      <Content />
    </section>

    <section class="links">
      {project.data.github && (
        <a href={project.data.github} class="link-button" target="_blank" rel="noopener">
          GitHub Repository
        </a>
      )}
      {project.data.demo && (
        <a href={project.data.demo} class="link-button demo" target="_blank" rel="noopener">
          Live Demo
        </a>
      )}
    </section>

    {project.data.type === 'web' && project.data.demo && (
      <section class="demo-frame">
        <h2>Live Preview</h2>
        <iframe src={project.data.demo} title={project.data.title} loading="lazy"></iframe>
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .project-detail {
    padding: 2rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: var(--text-muted);
  }

  .back-link:hover {
    color: var(--primary);
  }

  header {
    margin-bottom: 2rem;
  }

  h1 {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  .description {
    color: var(--text-muted);
    font-size: 1.125rem;
    margin-bottom: 1rem;
  }

  .tech-stack {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .project-image {
    width: 100%;
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 2rem;
    background: var(--card-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 300px;
  }

  .project-image img {
    width: 100%;
    height: auto;
  }

  .project-image-placeholder {
    flex-direction: column;
    gap: 1rem;
    color: var(--text-muted);
  }

  .placeholder-icon {
    width: 64px;
    height: 64px;
    opacity: 0.5;
  }

  .placeholder-text {
    font-size: 0.875rem;
    opacity: 0.6;
  }

  .content {
    background: var(--card-bg);
    padding: 1.5rem;
    border-radius: 8px;
    margin-bottom: 2rem;
  }

  .links {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .link-button {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: var(--primary);
    color: white;
    border-radius: 6px;
    font-weight: 500;
  }

  .link-button:hover {
    text-decoration: none;
    opacity: 0.9;
  }

  .link-button.demo {
    background: #10b981;
  }

  .demo-frame {
    margin-bottom: 2rem;
  }

  .demo-frame h2 {
    margin-bottom: 1rem;
  }

  .demo-frame iframe {
    width: 100%;
    height: 500px;
    border: 1px solid var(--border);
    border-radius: 8px;
  }
</style>
