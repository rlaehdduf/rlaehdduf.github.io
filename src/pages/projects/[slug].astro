---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TechBadge from '../../components/TechBadge.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={project.data.title}>
  <article class="project-detail">
    <a href="/" class="back-link">← Back to Projects</a>

    <header>
      <h1>{project.data.title}</h1>
      <p class="description">{project.data.description}</p>
      <div class="tech-stack">
        {project.data.technologies.map((tech) => <TechBadge name={tech} />)}
      </div>
    </header>

    {project.data.image && (
      <div class="project-image">
        <img src={project.data.image} alt={project.data.title} />
      </div>
    )}

    <section class="content">
      <Content />
    </section>

    <section class="links">
      {project.data.github && (
        <a href={project.data.github} class="link-button" target="_blank" rel="noopener">
          GitHub Repository
        </a>
      )}
      {project.data.demo && (
        <a href={project.data.demo} class="link-button demo" target="_blank" rel="noopener">
          Live Demo
        </a>
      )}
    </section>

    {project.data.type === 'web' && project.data.demo && (
      <section class="demo-frame">
        <h2>Live Preview</h2>
        <iframe src={project.data.demo} title={project.data.title} loading="lazy"></iframe>
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .project-detail {
    padding: 2rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: var(--text-muted);
  }

  .back-link:hover {
    color: var(--primary);
  }

  header {
    margin-bottom: 2rem;
  }

  h1 {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  .description {
    color: var(--text-muted);
    font-size: 1.125rem;
    margin-bottom: 1rem;
  }

  .tech-stack {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .project-image {
    width: 100%;
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 2rem;
    background: var(--card-bg);
  }

  .project-image img {
    width: 100%;
    height: auto;
  }

  .content {
    background: var(--card-bg);
    padding: 1.5rem;
    border-radius: 8px;
    margin-bottom: 2rem;
  }

  .links {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .link-button {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: var(--primary);
    color: white;
    border-radius: 6px;
    font-weight: 500;
  }

  .link-button:hover {
    text-decoration: none;
    opacity: 0.9;
  }

  .link-button.demo {
    background: #10b981;
  }

  .demo-frame {
    margin-bottom: 2rem;
  }

  .demo-frame h2 {
    margin-bottom: 1rem;
  }

  .demo-frame iframe {
    width: 100%;
    height: 500px;
    border: 1px solid var(--border);
    border-radius: 8px;
  }
</style>