---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const featuredProjects = projects.filter(p => p.data.featured);
const otherProjects = projects.filter(p => !p.data.featured);
---

<BaseLayout title="My Portfolio">
  <section class="hero">
    <h1>My Projects</h1>
    <p>Unity Games, Web Applications, and Tools</p>
  </section>

  {featuredProjects.length > 0 && (
    <section class="section">
      <h2>Featured Projects</h2>
      <div class="card-grid">
        {featuredProjects.map((project) => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            image={project.data.image}
            technologies={project.data.technologies}
            slug={project.id}
            featured={project.data.featured}
            devPeriod={project.data.devPeriod}
            type={project.data.type}
          />
        ))}
      </div>
    </section>
  )}

  <section class="section">
    <h2>All Projects</h2>
    <div class="card-grid">
      {otherProjects.map((project) => (
        <ProjectCard
          title={project.data.title}
          description={project.data.description}
          image={project.data.image}
          technologies={project.data.technologies}
          slug={project.id}
          featured={project.data.featured}
          devPeriod={project.data.devPeriod}
          type={project.data.type}
        />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== Hero ===== */
  .hero {
    padding: 4rem 2rem;
    text-align: center;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }

  .hero p {
    color: var(--text-secondary);
    font-size: 1.125rem;
  }

  /* ===== Section ===== */
  .section {
    padding: 2rem;
  }

  .section h2 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    padding-left: 0.75rem;
    border-left: 3px solid var(--cyan);
    color: var(--text-primary);
  }

  /* ===== Card Grid ===== */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  /* ===== Hover 시 다른 카드 opacity 효과 ===== */
  .card-grid:hover :global(.project-card) {
    opacity: 0.6;
  }

  .card-grid:hover :global(.project-card:hover) {
    opacity: 1;
  }

  /* ===== Responsive ===== */
  @media (max-width: 640px) {
    .hero {
      padding: 2rem 1rem;
    }

    h1 {
      font-size: 2rem;
    }

    .section {
      padding: 1rem;
    }

    .card-grid {
      grid-template-columns: 1fr;
    }
  }
</style>